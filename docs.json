{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Docket",
  "theme": "palm",
  "colors": {
    "primary": "#040404",
    "light": "#f4a261",
    "dark": "#040404"
  },
  "favicon": "https://media.brand.dev/afdc0299-a24a-4b2a-b0a3-72518364e6ae.svg",
  "logo": {
    "light": "https://media.brand.dev/902e35a1-9ce2-4fd1-b86c-a00efd97370b.svg",
    "dark": "https://media.brand.dev/902e35a1-9ce2-4fd1-b86c-a00efd97370b.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/lordexodius/docket"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/lordexodius/docket"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/markdown-editing",
              "features/note-management",
              "features/keyboard-shortcuts",
              "features/themes-and-styling"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/using-editor",
              "guides/organizing-notes",
              "guides/importing-exporting",
              "guides/customization"
            ]
          }
        ]
      },
      {
        "tab": "Development",
        "groups": [
          {
            "group": "Developer Guide",
            "pages": [
              "development/architecture",
              "development/building",
              "development/api-reference"
            ]
          },
          {
            "group": "Contributing",
            "pages": [
              "development/contributing",
              "development/roadmap"
            ]
          }
        ]
      }
    ]
  }
}
